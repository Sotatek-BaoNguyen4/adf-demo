{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$metadata": {
    "project": "ADF Cinema",
    "version": "2.0.0",
    "description": "Youth-friendly cinematic design system — Material Design 3 (Material You) compliant, Flutter mobile",
    "style": "Dark Cinematic + Material Design 3",
    "audience": "Gen-Z / Youth (16-28)",
    "updated": "2026-05-27",
    "spec": "https://m3.material.io/styles"
  },

  "color": {
    "brand": {
      "primary": { "$type": "color", "$value": "#7C3AED", "$description": "Seed color — Electric Violet" },
      "secondary": { "$type": "color", "$value": "#06B6D4", "$description": "Seed color — Cyan accent" },
      "tertiary": { "$type": "color", "$value": "#F97316", "$description": "Seed color — Warm Orange" }
    },

    "primary": {
      "$description": "M3 primary color roles",
      "default": { "$type": "color", "$value": "#D0BCFF" },
      "on": { "$type": "color", "$value": "#381E72" },
      "container": { "$type": "color", "$value": "#4F378B" },
      "on-container": { "$type": "color", "$value": "#EADDFF" }
    },
    "secondary": {
      "$description": "M3 secondary color roles",
      "default": { "$type": "color", "$value": "#67E8F9" },
      "on": { "$type": "color", "$value": "#003738" },
      "container": { "$type": "color", "$value": "#00565A" },
      "on-container": { "$type": "color", "$value": "#A2EFF8" }
    },
    "tertiary": {
      "$description": "M3 tertiary color roles — cinematic orange warmth",
      "default": { "$type": "color", "$value": "#FDB97D" },
      "on": { "$type": "color", "$value": "#4A2800" },
      "container": { "$type": "color", "$value": "#6B3D00" },
      "on-container": { "$type": "color", "$value": "#FFDCBE" }
    },
    "error": {
      "$description": "M3 error color roles",
      "default": { "$type": "color", "$value": "#FFB4AB" },
      "on": { "$type": "color", "$value": "#690005" },
      "container": { "$type": "color", "$value": "#93000A" },
      "on-container": { "$type": "color", "$value": "#FFDAD6" }
    },
    "surface": {
      "$description": "M3 surface color roles",
      "default": { "$type": "color", "$value": "#0A0A0F", "$description": "Base surface / app background" },
      "dim": { "$type": "color", "$value": "#070B14", "$description": "Dimmed surface — overlays, scrims" },
      "bright": { "$type": "color", "$value": "#1A1A24", "$description": "Brightened surface — elevated cards" },
      "container-lowest": { "$type": "color", "$value": "#050508" },
      "container-low": { "$type": "color", "$value": "#13131A" },
      "container": { "$type": "color", "$value": "#1A1A24" },
      "container-high": { "$type": "color", "$value": "#212130" },
      "container-highest": { "$type": "color", "$value": "#2D2D3D" }
    },
    "on-surface": {
      "$description": "M3 on-surface color roles",
      "default": { "$type": "color", "$value": "#E6E1E5", "$description": "Primary text on surface" },
      "variant": { "$type": "color", "$value": "#CAC4D0", "$description": "Secondary text / icons on surface" }
    },
    "outline": {
      "$description": "M3 outline roles",
      "default": { "$type": "color", "$value": "#938F99", "$description": "Input borders, dividers" },
      "variant": { "$type": "color", "$value": "#49454F", "$description": "Subtle borders, card edges" }
    },
    "inverse": {
      "surface": { "$type": "color", "$value": "#E6E1E5" },
      "on-surface": { "$type": "color", "$value": "#313033" },
      "primary": { "$type": "color", "$value": "#7C3AED", "$description": "Links on inverse surface" }
    },
    "scrim": { "$type": "color", "$value": "#000000" },
    "shadow": { "$type": "color", "$value": "#000000" },

    "semantic": {
      "success": { "$type": "color", "$value": "#22C55E" },
      "warning": { "$type": "color", "$value": "#F59E0B" },
      "info": { "$type": "color", "$value": "#3B82F6" }
    },

    "background": {
      "app": { "$type": "color", "$value": "#0A0A0F" },
      "surface": { "$type": "color", "$value": "#13131A" },
      "elevated": { "$type": "color", "$value": "#1A1A24" },
      "overlay": { "$type": "color", "$value": "#00000080" }
    },
    "text": {
      "primary": { "$type": "color", "$value": "#E6E1E5" },
      "secondary": { "$type": "color", "$value": "#CAC4D0" },
      "muted": { "$type": "color", "$value": "#938F99" },
      "inverse": { "$type": "color", "$value": "#313033" },
      "on-primary": { "$type": "color", "$value": "#381E72" }
    },
    "border": {
      "default": { "$type": "color", "$value": "#49454F" },
      "focus": { "$type": "color", "$value": "#D0BCFF" },
      "strong": { "$type": "color", "$value": "#938F99" }
    },
    "interactive": {
      "primary": { "$type": "color", "$value": "#D0BCFF" },
      "primary-hover": { "$type": "color", "$value": "#E8DEF8" },
      "primary-pressed": { "$type": "color", "$value": "#B69DF8" },
      "primary-disabled": { "$type": "color", "$value": "#D0BCFF40" },
      "secondary": { "$type": "color", "$value": "#67E8F9" },
      "secondary-hover": { "$type": "color", "$value": "#A2EFF8" },
      "destructive": { "$type": "color", "$value": "#FFB4AB" }
    },
    "badge": {
      "now-showing": { "$type": "color", "$value": "#4F378B" },
      "coming-soon": { "$type": "color", "$value": "#00565A" },
      "rating": { "$type": "color", "$value": "#FBBF24" },
      "new": { "$type": "color", "$value": "#22C55E" }
    },
    "nav": {
      "background": { "$type": "color", "$value": "#13131AE6" },
      "active": { "$type": "color", "$value": "#D0BCFF" },
      "inactive": { "$type": "color", "$value": "#938F99" }
    }
  },

  "dimension": {
    "spacing": {
      "$description": "8dp M3 grid — base unit 4px, primary steps at 8px multiples",
      "0": { "$type": "dimension", "$value": "0px" },
      "1": { "$type": "dimension", "$value": "4px" },
      "2": { "$type": "dimension", "$value": "8px" },
      "3": { "$type": "dimension", "$value": "12px" },
      "4": { "$type": "dimension", "$value": "16px" },
      "5": { "$type": "dimension", "$value": "20px" },
      "6": { "$type": "dimension", "$value": "24px" },
      "8": { "$type": "dimension", "$value": "32px" },
      "10": { "$type": "dimension", "$value": "40px" },
      "12": { "$type": "dimension", "$value": "48px" },
      "16": { "$type": "dimension", "$value": "64px" },
      "20": { "$type": "dimension", "$value": "80px" }
    },
    "shape": {
      "$description": "M3 shape scale — rounded corners are central to Material You",
      "none": { "$type": "dimension", "$value": "0px", "$description": "No rounding" },
      "extra-small": { "$type": "dimension", "$value": "4px", "$description": "Chips, text fields, menus, tooltips" },
      "small": { "$type": "dimension", "$value": "8px", "$description": "Buttons, FAB small, icon buttons" },
      "medium": { "$type": "dimension", "$value": "12px", "$description": "Cards, date picker, time picker" },
      "large": { "$type": "dimension", "$value": "16px", "$description": "Navigation drawer, dialogs, side sheet" },
      "extra-large": { "$type": "dimension", "$value": "28px", "$description": "FAB, extended FAB, bottom sheets top edge" },
      "full": { "$type": "dimension", "$value": "9999px", "$description": "Badges, switches, search bar, sliders" }
    },
    "icon": {
      "xs": { "$type": "dimension", "$value": "16px" },
      "sm": { "$type": "dimension", "$value": "20px" },
      "md": { "$type": "dimension", "$value": "24px", "$description": "M3 standard icon size" },
      "lg": { "$type": "dimension", "$value": "32px" },
      "xl": { "$type": "dimension", "$value": "48px" }
    },
    "touch-target": {
      "min": { "$type": "dimension", "$value": "48px", "$description": "M3 minimum touch target (48dp)" }
    },
    "elevation": {
      "$description": "M3 elevation levels in dp — visual depth via tonal color overlay, not shadow alone",
      "level-0": { "$type": "dimension", "$value": "0px", "$description": "Flat surfaces — surface" },
      "level-1": { "$type": "dimension", "$value": "1px", "$description": "Cards resting on surface" },
      "level-2": { "$type": "dimension", "$value": "3px", "$description": "FAB, menus" },
      "level-3": { "$type": "dimension", "$value": "6px", "$description": "Navigation drawer, modal bottom sheet" },
      "level-4": { "$type": "dimension", "$value": "8px", "$description": "Navigation bar" },
      "level-5": { "$type": "dimension", "$value": "12px", "$description": "Top app bar (scrolled)" }
    }
  },

  "fontFamily": {
    "heading": {
      "$type": "fontFamily",
      "$value": ["Poppins", "Roboto", "sans-serif"],
      "$description": "M3 compatible — Poppins for cinematic youth brand, Roboto as system fallback"
    },
    "body": {
      "$type": "fontFamily",
      "$value": ["Inter", "Roboto", "sans-serif"],
      "$description": "Clean readable font — Inter preferred, Roboto M3 system fallback"
    },
    "display": {
      "$type": "fontFamily",
      "$value": ["Righteous", "Poppins", "sans-serif"],
      "$description": "Splash / marketing hero text — expressive style"
    }
  },

  "fontSize": {
    "$description": "M3 type scale — Display / Headline / Title / Body / Label",
    "display-large": { "$type": "dimension", "$value": "57px" },
    "display-medium": { "$type": "dimension", "$value": "45px" },
    "display-small": { "$type": "dimension", "$value": "36px" },
    "headline-large": { "$type": "dimension", "$value": "32px" },
    "headline-medium": { "$type": "dimension", "$value": "28px" },
    "headline-small": { "$type": "dimension", "$value": "24px" },
    "title-large": { "$type": "dimension", "$value": "22px" },
    "title-medium": { "$type": "dimension", "$value": "16px" },
    "title-small": { "$type": "dimension", "$value": "14px" },
    "body-large": { "$type": "dimension", "$value": "16px" },
    "body-medium": { "$type": "dimension", "$value": "14px" },
    "body-small": { "$type": "dimension", "$value": "12px" },
    "label-large": { "$type": "dimension", "$value": "14px" },
    "label-medium": { "$type": "dimension", "$value": "12px" },
    "label-small": { "$type": "dimension", "$value": "11px" }
  },

  "fontWeight": {
    "regular": { "$type": "fontWeight", "$value": 400 },
    "medium": { "$type": "fontWeight", "$value": 500 },
    "semibold": { "$type": "fontWeight", "$value": 600 },
    "bold": { "$type": "fontWeight", "$value": 700 }
  },

  "lineHeight": {
    "$description": "M3 line height scale — matches type scale",
    "display-large": { "$type": "number", "$value": 1.123 },
    "display-medium": { "$type": "number", "$value": 1.156 },
    "display-small": { "$type": "number", "$value": 1.222 },
    "headline-large": { "$type": "number", "$value": 1.25 },
    "headline-medium": { "$type": "number", "$value": 1.286 },
    "headline-small": { "$type": "number", "$value": 1.333 },
    "title-large": { "$type": "number", "$value": 1.273 },
    "title-medium": { "$type": "number", "$value": 1.5 },
    "title-small": { "$type": "number", "$value": 1.429 },
    "body-large": { "$type": "number", "$value": 1.5 },
    "body-medium": { "$type": "number", "$value": 1.429 },
    "body-small": { "$type": "number", "$value": 1.333 },
    "label-large": { "$type": "number", "$value": 1.429 },
    "label-medium": { "$type": "number", "$value": 1.333 },
    "label-small": { "$type": "number", "$value": 1.455 }
  },

  "duration": {
    "$description": "M3 motion tokens — use emphasized easing for hero transitions",
    "short-1": { "$type": "duration", "$value": "50ms" },
    "short-2": { "$type": "duration", "$value": "100ms" },
    "short-3": { "$type": "duration", "$value": "150ms", "$description": "Micro-interactions, ripple, icon swap" },
    "short-4": { "$type": "duration", "$value": "200ms" },
    "medium-1": { "$type": "duration", "$value": "250ms", "$description": "Card reveals, FAB open/close" },
    "medium-2": { "$type": "duration", "$value": "300ms", "$description": "Dialogs, bottom sheets" },
    "medium-3": { "$type": "duration", "$value": "350ms" },
    "medium-4": { "$type": "duration", "$value": "400ms" },
    "long-1": { "$type": "duration", "$value": "450ms", "$description": "Page transitions (emphasized easing)" },
    "long-2": { "$type": "duration", "$value": "500ms", "$description": "Complex page transitions" },
    "extra-long-4": { "$type": "duration", "$value": "1500ms", "$description": "Skeleton loading shimmer" }
  },

  "shadow": {
    "$description": "M3 elevation shadows — paired with tonal color overlay in dark theme",
    "level-0": {
      "$type": "shadow",
      "$value": { "offsetX": "0px", "offsetY": "0px", "blur": "0px", "spread": "0px", "color": "#00000000" }
    },
    "level-1": {
      "$type": "shadow",
      "$value": { "offsetX": "0px", "offsetY": "1px", "blur": "2px", "spread": "0px", "color": "#00000033" }
    },
    "level-2": {
      "$type": "shadow",
      "$value": { "offsetX": "0px", "offsetY": "2px", "blur": "6px", "spread": "2px", "color": "#00000033" }
    },
    "level-3": {
      "$type": "shadow",
      "$value": { "offsetX": "0px", "offsetY": "4px", "blur": "8px", "spread": "3px", "color": "#00000040" }
    },
    "level-4": {
      "$type": "shadow",
      "$value": { "offsetX": "0px", "offsetY": "6px", "blur": "10px", "spread": "4px", "color": "#00000040" }
    },
    "level-5": {
      "$type": "shadow",
      "$value": { "offsetX": "0px", "offsetY": "8px", "blur": "12px", "spread": "6px", "color": "#00000040" }
    },
    "glow-primary": {
      "$type": "shadow",
      "$value": { "offsetX": "0px", "offsetY": "0px", "blur": "20px", "spread": "0px", "color": "#D0BCFF40" },
      "$description": "Violet glow for focused/active elements — cinematic accent"
    }
  },

  "$gradients": {
    "$description": "Reference values only — not W3C DTCG tokens. Use directly in Flutter/CSS.",
    "primary": "linear-gradient(135deg, #7C3AED 0%, #A78BFA 100%)",
    "cinematic": "linear-gradient(180deg, transparent 0%, #0A0A0F 100%)",
    "accent": "linear-gradient(135deg, #7C3AED 0%, #06B6D4 100%)"
  }
}
